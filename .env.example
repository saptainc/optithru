# OptiThru deployment configuration template.
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Network ──
# Macvlan IP for the frontend container on macvlansp6
APP_IP=10.1.45.1

# ── Application URLs ──
# Public URL of OptiThru (HTTPS terminated by external nginx-proxy-manager)
APP_URL=https://shankara.sapta.com
# Supabase API URL — routed through Next.js rewrites at /supabase/*
SUPABASE_EXTERNAL_URL=https://shankara.sapta.com/supabase

# ── Supabase Secrets ──
# Postgres role password — MUST match the password hardcoded in
# supabase/volumes/db/init/00-schema.sql. To change for production,
# update both this file and the schema file BEFORE first start.
POSTGRES_PASSWORD=optithru-super-secret-postgres-password-2025

# JWT secret — MUST match the secret used to sign ANON_KEY and SERVICE_ROLE_KEY.
# The Supabase demo keys below are signed with this exact secret.
# If you generate new keys, update both this and the keys.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Demo Supabase JWT keys (signed with the JWT_SECRET above).
# Generate fresh keys for production: https://supabase.com/docs/guides/self-hosting
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ── Fizzy TOC Kanban ──
# Public URL of the Fizzy kanban (separate subdomain, also via NPM)
KANBAN_URL=https://kanbanshankara.sapta.com

# Generate with: openssl rand -hex 32
FIZZY_EMBED_SECRET=

# Generate with: openssl rand -hex 64
# Fizzy uses this instead of config/master.key for production secret_key_base
SECRET_KEY_BASE=

# ── Populated AFTER first SSO + bootstrap.sh ──
# Get these by running ./bootstrap.sh after the first browser SSO:
#   FIZZY_ACCESS_TOKEN  — Identity access token (must have permission='write')
#   FIZZY_BOARD_ID      — UUID of the Strategic Kanban board
#   FIZZY_ACCOUNT_SLUG  — Account slug used in Fizzy URLs (typically "1")
FIZZY_ACCESS_TOKEN=
FIZZY_BOARD_ID=
FIZZY_ACCOUNT_SLUG=1
